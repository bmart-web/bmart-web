---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
const whatsapp = "https://wa.me/593984919911?text=Hola%20BMART%2C%20quiero%20informaci%C3%B3n%20sobre%20CCTV";
---

<Layout title="Cámaras de seguridad CCTV en Ecuador | BMART" description="BMART implementa cámaras de seguridad CCTV, videovigilancia y soluciones de monitoreo para empresas en Ecuador.">
	<Header />
	<main>
		<section class="hero">
			<p class="eyebrow">Videovigilancia empresarial</p>
			<h1>Cámaras de seguridad CCTV para empresas</h1>
			<p>Diseñamos e implementamos sistemas de videovigilancia para oficinas, bodegas, locales comerciales e infraestructura corporativa.</p>
			<div class="actions">
				<a
    class="primary"
    href={whatsapp}
    target="_blank"
    rel="noopener noreferrer"
    onclick="gtag('event', 'click_whatsapp', {
      event_category: 'contacto',
      event_label: 'cctv'
    })"
  >
    Solicitar asesoría
  </a>
				<a class="secondary" href="/">Volver al inicio</a>
			</div>
        
		</section>
	</main>
<footer>
	<div>
		<strong>BMART</strong>
		<p>Soluciones tecnológicas, ciberseguridad, IA, redes y desarrollo de software para empresas en Ecuador.</p>
	</div>

	<div>
		<h4>Servicios</h4>
		<a href="/ciberseguridad-sophos">Ciberseguridad Sophos</a>
		<a href="/camaras-seguridad-cctv">CCTV</a>
		<a href="/desarrollo-software-integraciones-api">APIs</a>
		<a href="/redes-infraestructura">Redes</a>
	</div>

	<div>
		<h4>Contacto</h4>
		<a
    href={whatsapp}
    target="_blank"
    rel="noopener noreferrer"
    onclick="gtag('event', 'click_whatsapp_footer', {
      event_category: 'contacto',
      event_label: 'cctv_footer'
    })"
  >
    WhatsApp
  </a>
  		<a href="mailto:info@bmart.com.ec">info@bmart.com.ec</a>
	</div>
</footer>
	<a
  class="float"
  href={whatsapp}
  target="_blank"
  rel="noopener noreferrer"
  onclick="gtag('event', 'click_whatsapp_float', {
    event_category: 'contacto',
    event_label: 'cctv_float'
  })"
>
  WhatsApp
</a>
</Layout>